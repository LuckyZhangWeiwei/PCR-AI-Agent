{
  "name": "pcr-ai-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "RESTful API for PCR AI backed by Oracle (oracledb pool)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node scripts/copy-perlscripts.mjs && node scripts/verify-dist-no-undici.mjs",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "agent:eval": "tsx test/eval/runEval.ts",
    "docs:api-v3": "npm run build && node scripts/write-api-v3-doc.mjs",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:reload": "npm run build && pm2 reload ecosystem.config.cjs"
  },
  "engines": {
    "node": ">=18.12.1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "oracledb": "5.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "~18.19.64",
    "@types/oracledb": "5.3.1",
    "tsx": "^4.19.2",
    "typescript": "~5.3.3"
  }
}
