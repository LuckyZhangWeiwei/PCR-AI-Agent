# --- 浏览器跨域（CORS）---
# 本 API **固定最宽松** CORS（代码内写死：任意 Origin 回显、预检头回显、不带 cookie），无需也不读取 CORS_ORIGIN / CORS_CREDENTIALS。

# -----------------------------------------------------------------------------
# 重要：dotenv 只会加载「.env」，不会加载「.env.example」。
# 请在本目录复制一份：copy .env.example .env（或手动新建 .env），再修改变量。
# -----------------------------------------------------------------------------
#
# --- NJS-116（本机 Thin 模式）---
# 若查询报错 password verifier type … not supported in Thin mode：
#   - 在此机安装 Oracle Instant Client，设置 ORACLE_INSTANT_CLIENT_LIB_DIR（Windows 指向含 oci.dll 的目录），重启本服务；或
#   - 只调试前端：不要启动本仓库的 Node API，只运行 pcr-ai-report，页面「服务器地址」填已部署的网关（已启用 Thick），例如内网 http://10.192.130.89:30008
#
# --- 正式环境（Oracle 真实数据）---
# 填写下方 ORACLE_*（及 probeweb 相关变量）；不要将 Dummy 设为开启：
#   YIELD_MONITOR_TRIGGERS_DUMMY=false（或不写；PM2 默认亦为 false）
#   INFCONTROL_LAYER_BINS_DUMMY=false（同上）
# 仅本地联调无库时，才将上述两项设为 true。
#
# Oracle（与 smartfactory-exmatrix-api 相同环境变量名）
# 示例业务账号：jbstar_loader（密码勿提交仓库，用本机 .env）
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=

# Oracle probeweb（产量相关路由；推荐 URL 前缀 /api/v3，例如 GET /api/v3/yield-monitor-triggers/v3）；连接串默认同 ORACLE_CONNECT_STRING
# ORACLE_PROBEWEB_USER=probeweb
# ORACLE_PROBEWEB_PASSWORD=
# ORACLE_PROBEWEB_CONNECT_STRING=

# -----------------------------------------------------------------------------
# DPI-1050（Oracle Client 版本过低）
# node-oracledb 6.x 的 Thick 模式需要 **Oracle Instant Client / Client >= 18.1**。
# 若 detail 含 DPI-1050 且当前为 11.2：请安装 **Instant Client 19+**，设置 **ORACLE_INSTANT_CLIENT_LIB_DIR**
# 指向解压目录（含 libclntsh.so / oci.dll），并避免让 **ORACLE_HOME** 仍指向 11g 的 lib 抢先被加载；重启 PM2。
# 内网旧路径 /u01/.../client_11.2 若存在仍会尝试加载（与旧行为一致）。若在新环境必须禁止该回退，设：
# ORACLE_SKIP_LEGACY_CLIENT_11=true
# -----------------------------------------------------------------------------
# 将下方取消注释并改成你服务器上 Instant Client 目录（内含 libclntsh.so / oci.dll），
# 然后重启 PM2（或 Node 进程）。启动时 oracle.ts 会调用 oracledb.initOracleClient({ libDir })。
# 这与 Dummy 开关无关：dummy 仅跳过真实查询，不能替代 Thick。
# -----------------------------------------------------------------------------
# Linux / PM2 / Docker：同上，指向解压后的 Instant Client 目录（内含 libclntsh.so）
# ORACLE_INSTANT_CLIENT_LIB_DIR=/opt/oracle/instantclient_21_16
# 可选：LD_LIBRARY_PATH 也可设为同一目录（按 Oracle 文档）
#
# Windows：指向含 oci.dll 的目录
# ORACLE_INSTANT_CLIENT_LIB_DIR=C:\\oracle\\instantclient_21_16
# 可选：tnsnames.ora / sqlnet.ora 所在目录
# ORACLE_CLIENT_CONFIG_DIR=
# 连接池（可按负载在 .env 中调大 ORACLE_POOL_MAX 等；默认与早期版本一致为 4）
# ORACLE_POOL_MIN=0
# ORACLE_POOL_MAX=4
# ORACLE_POOL_INCREMENT=1
# 从池中取连接的排队超时（毫秒），默认 60000；仅调大不能替代调大 poolMax / 优化慢 SQL
# ORACLE_QUEUE_TIMEOUT=60000
# 产量路由专用 probeweb 池（未设置则与主池共用 ORACLE_POOL_* 数值）
# ORACLE_PROBEWEB_POOL_MIN=
# ORACLE_PROBEWEB_POOL_MAX=
# ORACLE_PROBEWEB_POOL_INCREMENT=
# 单次数据库往返最大耗时（毫秒），0 表示不限制（默认 0）
# ORACLE_CALL_TIMEOUT_MS=
# 借连接执行整段回调超过该毫秒数时打 warn；默认关闭，需排查慢 SQL 时再设正数
# ORACLE_SLOW_QUERY_LOG_MS=

# GET /api/v3/table-rows（与 /api/v1/table-rows 同路由）未传 table= 时使用的默认表（TABLE 或 SCHEMA.TABLE）
# ORACLE_DEFAULT_TABLE=MY_TABLE

# **v4** 层控与产量聚合在 **Oracle** 路径下于 Node 内聚合时，单次允许拉取的最大匹配行数（防 OOM；超出返回 422 QUERY_TOO_LARGE）。**v3** Oracle 聚合仍在库内完成，不使用本上限。
# 正整数，默认 200000，上限 5000000。
# MEMORY_AGG_ORACLE_MAX_ROWS=200000

PORT=3000

# --- 硅基流动（可选）---
# GET /api/v1/siliconflow/chat?message=你好 等（同路由亦挂在 /api/v3、/api/v4）
# 文档：https://docs.siliconflow.cn/cn/api-reference/chat-completions/chat-completions
# API Key 已硬编码在 src/lib/siliconflowChat.ts（SILICONFLOW_API_KEY 常量）；无需在 .env 配置密钥。
# 可选：若将来改回 env 覆盖，可取消下行注释（当前代码不读取本变量）
# SILICONFLOW_API_KEY=
# 默认 Pro/MiniMaxAI/MiniMax-M2.5；可改为控制台中的其它模型 id
# SILICONFLOW_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
# 默认 https://api.siliconflow.cn/v1
# SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
# 出站调用硅基流动超时（毫秒），默认 60000，范围 5000–120000
# SILICONFLOW_FETCH_TIMEOUT_MS=60000
# 企业 HTTPS 解密（自签证书链）时：设为 true 后仅对硅基流动出站跳过 TLS 校验（有 MITM 风险）。若未设置，代码内默认与 true 相同（方便无法改服务器 .env 的部署）；要强制校验请设 SILICONFLOW_TLS_STRICT=true
# SILICONFLOW_TLS_INSECURE=true
# 与上两者相反：强制校验 TLS（证书链不通过则失败）
# SILICONFLOW_TLS_STRICT=true
# 更稳妥：Node 额外信任企业根 CA PEM 文件路径（与 TLS_INSECURE 二选一优先用本项）
# NODE_EXTRA_CA_CERTS=/path/to/corp-root.pem

# 测试 / 无 Oracle probeweb：v3 列表 GET /api/v3/yield-monitor-triggers/v3（同路由亦挂载在 /api/v1/...）可走内存样本，不连库（传参与 JSON 形状与真实接口一致）
# 设为 1 / true / yes；或 NODE_ENV=test 时也会启用 dummy（无需再设本变量）
# 注意：`npm run build` 后的 dist 进程，或 NODE_ENV=production 时，Dummy 恒关（走 Oracle），本变量无效。
# YIELD_MONITOR_TRIGGERS_DUMMY=true

# 测试 / 无 Oracle 主库：v3 层控 GET /api/v3/infcontrol-layer-bins/v3 与 …/v3/aggregate（同路由亦挂载在 /api/v1/...）可走内存样本，不连库（传参与 JSON 形状与真实接口一致）
# PM2 下 NODE_ENV 常为 production，若未配置 Oracle，显式打开本变量可跳过主库查询（联调用）
# 设为 1 / true / yes；或 NODE_ENV=test 时也会启用 dummy
# 注意：`npm run build` 后的 dist 进程，或 NODE_ENV=production 时，Dummy 恒关（走 Oracle），本变量无效。
# INFCONTROL_LAYER_BINS_DUMMY=true
